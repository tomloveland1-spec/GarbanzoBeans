+) -> Result<Transaction, AppError> {
+    let conn = state.0.lock().map_err(|_| AppError {
+        code: "DB_LOCK_POISON".to_string(),
+        message: "Database mutex was poisoned.".to_string(),
+    })?;
+    create_transaction_inner(&conn, &input)
+}
